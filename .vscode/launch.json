{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API server (dev)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/tsx",
      "runtimeArgs": ["watch", "src/server/index.ts"],
      "env": { "NODE_ENV": "development" },
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "API server (production)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/tsx",
      "runtimeArgs": ["src/server/index.ts"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "Full dev (Vite + API)",
      "configurations": ["API server (dev)"],
      "preLaunchTask": "vite-dev"
    }
  ]
}
