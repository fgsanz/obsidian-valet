{
  "name": "obsidian-valet",
  "version": "0.2.2",
  "description": "A local tool for manipulating Obsidian vault notes",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"vite,server\" -c \"cyan,yellow\" \"vite\" \"NODE_ENV=development tsx watch src/server/index.ts\"",
    "build": "vite build",
    "start": "npm run build && tsx src/server/index.ts",
    "preview": "npm run start",
    "check-docs": "tsx scripts/check-docs.ts",
    "sync-readme": "tsx scripts/sync-readme.ts",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:bdd",
    "test:unit": "node --import tsx --import ./tests/support/test-setup.mjs --test \"tests/unit/**/*.test.ts\" \"tests/unit/**/*.test.tsx\"",
    "test:bdd": "node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js",
    "test:verbose": "node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js --format pretty",
    "test:keep": "KEEP_VAULT=1 node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js --format pretty",
    "coverage": "c8 --reporter=text --reporter=html npm test",
    "coverage:unit": "node --import tsx --test --experimental-test-coverage \"tests/unit/**/*.test.ts\""
  },
  "c8": {
    "include": [
      "src/**/*.ts",
      "src/**/*.tsx"
    ],
    "exclude": [
      "tests/**",
      "**/*.config.*",
      "src/client/main.tsx"
    ],
    "all": true,
    "reports-dir": "coverage"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "@tanstack/react-query": "^5.0.0",
    "chalk": "^5.0.0",
    "fastify": "^5.0.0",
    "js-yaml": "^4.1.0",
    "lucide-react": "^1.17.0",
    "marked": "^15.0.0",
    "open": "^10.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "simple-git": "^3.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "c8": "^10.1.3",
    "concurrently": "^9.0.0",
    "global-jsdom": "^29.0.0",
    "jsdom": "^29.1.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.16"
  }
}
